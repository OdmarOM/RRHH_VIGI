# ==========================================================
# Configuración de PRODUCCIÓN del backend RRHH
# Copia este archivo como ".env" y ajusta los valores.
# ==========================================================

# Clave secreta para firmar los tokens JWT.
# CAMBIA ESTO por una cadena larga y aleatoria. Ejemplo para generarla:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria

# Puerto y host del servidor.
# El backend también sirve el frontend compilado, así que este es el puerto
# donde se accede a la aplicación. Evita los puertos 8000-8010 si ya los usas.
HOST=0.0.0.0
PORT=8090

# Duración de la sesión en minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Base de datos (por defecto SQLite local).
# Para PostgreSQL: postgresql+psycopg://usuario:password@host:5432/rrhh
# DATABASE_URL=sqlite:///./rrhh_dev.db

# Orígenes permitidos para CORS (JSON). Al servir el frontend desde el
# mismo backend no es necesario, pero se configura el propio por defecto.
# Puedes añadir dominios/IPs si accedes desde otra máquina.
# CORS_ORIGINS=["http://localhost:8090","http://127.0.0.1:8090"]
