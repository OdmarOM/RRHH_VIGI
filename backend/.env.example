# ==========================================================
# Configuración de PRODUCCIÓN del backend RRHH
# Copia este archivo como ".env" y ajusta los valores.
# ==========================================================

# Clave secreta para firmar los tokens JWT.
# CAMBIA ESTO por una cadena larga y aleatoria. Ejemplo para generarla:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria

# Puerto y host del servidor (evita 8000, 8001, 8002, 8003)
HOST=0.0.0.0
PORT=8090

# Duración de la sesión en minutos (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Base de datos (por defecto SQLite local).
# Para PostgreSQL: postgresql+psycopg://usuario:password@host:5432/rrhh
# DATABASE_URL=sqlite:///./rrhh_dev.db

# Orígenes permitidos para CORS (JSON). Al servir en un solo puerto
# normalmente no se necesita, pero puedes añadir IPs si accedes remoto.
# CORS_ORIGINS=["http://192.168.1.50:8090"]
